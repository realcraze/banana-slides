:80 {
    root * /srv
    encode zstd gzip

    handle /api/* {
        reverse_proxy backend:5000
    }

    handle /files/* {
        reverse_proxy backend:5000
    }

    handle /health {
        reverse_proxy backend:5000
    }

    handle /avatars/* {
        file_server
    }

    handle {
        try_files {path} /index.html
        file_server
    }
}
